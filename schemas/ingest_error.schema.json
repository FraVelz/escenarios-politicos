{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://escenarios-politicos.local/schemas/ingest_error.schema.json",
  "title": "IngestError",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "country_id", "workflow_id", "reason", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "country_id": { "type": "string", "minLength": 2, "maxLength": 8 },
    "workflow_id": { "type": "string" },
    "reason": { "type": "string" },
    "payload": {
      "type": "object",
      "description": "Sanitizado: sin secretos ni cuerpos completos de fuente."
    },
    "created_at": { "type": "string" }
  }
}

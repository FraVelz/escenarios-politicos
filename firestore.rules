rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lectura pública del tablero. Escritura solo vía Admin SDK (/api/ingest).
    match /casos/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /menciones/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /indicadores/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /alertas/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /tensiones/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /senales/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /informes/{id} {
      allow read: if true;
      allow write: if false;
    }
    // Cola cruda e ingest: no visibles ni escribibles desde el cliente.
    match /raw_items/{id} {
      allow read, write: if false;
    }
    match /eventos/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /ingest_errors/{id} {
      allow read, write: if false;
    }
    match /ingest_runs/{id} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

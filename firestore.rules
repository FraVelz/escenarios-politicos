rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lectura pública del tablero. Escritura solo vía Admin SDK (/api/ingest).
    match /casos/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /menciones/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /indicadores/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /alertas/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /tensiones/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /senales/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /escenarios/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /instituciones/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /partidos/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /actores/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /marco/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /informes/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /raw_items/{id} {
      allow read, write: if false;
    }
    match /eventos/{id} {
      allow read: if true;
      allow write: if false;
    }
    // Errores de ingest: lectura para gaps; escritura solo Admin
    match /ingest_errors/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /ingest_runs/{id} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Firebase (web client — solo lectura pública)

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=escenarios-politicos-co.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=escenarios-politicos-co
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=escenarios-politicos-co.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=774079660369
NEXT_PUBLIC_FIREBASE_APP_ID=

# Ingesta n8n → POST /api/ingest (header x-ingest-secret)
# Generar: openssl rand -hex 32
INGEST_SECRET=
# Límite por IP por minuto (best-effort en memoria / instancia)
INGEST_RATE_LIMIT_PER_MIN=60

# Service account JSON en una sola línea (Admin SDK). No subir a git.
# Local: export FIREBASE_SERVICE_ACCOUNT_JSON="$(cat .firebase-admin.json)"
FIREBASE_SERVICE_ACCOUNT_JSON=
